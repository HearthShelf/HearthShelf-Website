{
  "plugins": ["react", "import"],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": ["app/**", "components/core/**", "components/media/**"],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Libre Baskerville))/i]",
        "message": "Font not provided by the design system. Available: Libre Baskerville."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|solid|icon|children|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: tone, solid, icon, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|now|done)$/]",
        "message": "<Badge> tone must be one of 'neutral' | 'now' | 'done'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TileBook'] > JSXAttribute > JSXIdentifier[name!=/^(?:progress|finished|key|ref|className|style|children)$/]",
        "message": "<TileBook> doesn't accept that prop. Declared props: progress, finished."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|icon|iconRight|fullWidth|disabled|children|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, icon, iconRight, fullWidth, disabled, children, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|pill|ghost|destructive)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'pill' | 'ghost' | 'destructive'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CoverBook'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|author|kicker|cv|key|ref|className|style|children)$/]",
        "message": "<CoverBook> doesn't accept that prop. Declared props: title, author, kicker, cv."
      },
      {
        "selector": "JSXOpeningElement[name.name='NavItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|label|active|onClick|style|key|ref|className|style|children)$/]",
        "message": "<NavItem> doesn't accept that prop. Declared props: icon, label, active, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='PlayBarBook'] > JSXAttribute > JSXIdentifier[name!=/^(?:hours|progress|key|ref|className|style|children)$/]",
        "message": "<PlayBarBook> doesn't accept that prop. Declared props: hours, progress."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgressBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|height|scrubber|style|key|ref|className|style|children)$/]",
        "message": "<ProgressBar> doesn't accept that prop. Declared props: value, height, scrubber, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stars'] > JSXAttribute > JSXIdentifier[name!=/^(?:rating|size|style|key|ref|className|style|children)$/]",
        "message": "<Stars> doesn't accept that prop. Declared props: rating, size, style."
      }
    ]
  },
  "overrides": [
    {
      "files": ["**/index.js"],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
    "components": {
      "Badge": {
        "replaces": []
      },
      "TileBook": {
        "replaces": []
      },
      "Button": {
